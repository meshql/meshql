{
  "name": "@meshql/pubsub",
  "version": "0.2.0",
  "description": "MeshQL pub/sub backends for real-time subscriptions (memory, Redis, Postgres)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "import": "./dist/redis.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "peerDependencies": {
    "pg": "^8.16.0",
    "redis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.10",
    "pg": "^8.21.0",
    "redis": "^6.1.0",
    "tsup": "^8.4.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
