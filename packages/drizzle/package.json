{
  "name": "@meshql/drizzle",
  "version": "0.7.3",
  "description": "MeshQL Drizzle adapter — catch-all resolver with relational query API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "dependencies": {
    "@meshql/core": "workspace:*"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "drizzle-orm": "^0.44.7",
    "tsup": "^8.4.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}
