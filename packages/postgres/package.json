{
  "name": "@meshql/postgres",
  "version": "0.5.4",
  "description": "MeshQL Postgres helper - build parameterized SELECT statements from a join plan",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --exclude='**/*.integration.test.ts'",
    "test:integration": "vitest run --testTimeout=60000 integration.test",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "dependencies": {
    "@meshql/core": "workspace:*"
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "tsup": "^8.4.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}
