{
  "name": "@meshql/gateway",
  "version": "0.2.0",
  "description": "Static multi-service MeshQL gateway — parallel fetch and stitch (V1)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "dependencies": {
    "@meshql/client": "workspace:*",
    "@meshql/core": "workspace:*"
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "tsup": "^8.4.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
