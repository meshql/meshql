{
  "name": "@meshql/kysely",
  "version": "0.6.0",
  "description": "MeshQL Kysely adapter — execute join plans as parameterized SQL",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "dependencies": {
    "@meshql/core": "workspace:*",
    "@meshql/postgres": "workspace:*",
    "@meshql/sqlite": "workspace:*"
  },
  "peerDependencies": {
    "kysely": ">=0.27.0"
  },
  "peerDependenciesMeta": {
    "kysely": {
      "optional": true
    }
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/node": "^26.1.0",
    "tsup": "^8.4.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  }
}
