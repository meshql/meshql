{
  "name": "@meshql/sqlite",
  "version": "0.5.4",
  "description": "MeshQL SQLite helper - build parameterized SELECT statements from a join plan, runs on Node's built-in node:sqlite",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "dependencies": {
    "@meshql/core": "workspace:*"
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "tsup": "^8.4.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.5"
  }
}
