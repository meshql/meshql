{
  "name": "@meshql/plugins",
  "version": "0.1.1",
  "description": "MeshQL plugin SDK for community extensions",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "peerDependencies": {
    "@meshql/core": "^0.1.4"
  },
  "devDependencies": {
    "@meshql/core": "workspace:*",
    "@meshql/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}
