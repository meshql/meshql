{
  "name": "@meshql/persisted-queries",
  "version": "0.2.1",
  "description": "MeshQL persisted query registry and X-Mesh-Query-Id transport",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "dependencies": {
    "@meshql/core": "workspace:*",
    "@meshql/http": "workspace:*"
  },
  "peerDependencies": {
    "express": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "express": "^5.1.0",
    "tsup": "^8.4.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
