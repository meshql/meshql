{
  "name": "@meshql/core",
  "version": "0.7.1",
  "description": "MeshQL core - parse queries, build join plans, shape responses",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./builtins": {
      "types": "./dist/builtins/index.d.ts",
      "import": "./dist/builtins/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "publish:jsr": "jsr publish"
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "tsup": "^8.4.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
