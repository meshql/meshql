# Server
PORT=3001

# Storage — leave unset for in-memory mode
# DATABASE_URL=postgresql://meshql:meshql@localhost:5432/meshql

# Security — leave unset to disable
# MESH_SECRET=dev-secret

# Full integrity auth (requires MESH_SECRET)
# MESH_INTEGRITY=1

# Client (demo-secure-client.ts)
# MESH_URL=http://localhost:3001/mesh
