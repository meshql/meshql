    "express": "^5.1.0"
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.3",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=22.5"
  }
}
