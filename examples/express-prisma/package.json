{
  "name": "express-prisma",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push && prisma generate",
    "dev": "tsx watch src/server.ts",
