{
  "name": "express-prisma",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push && prisma generate",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "demo": "tsx src/demo-client.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@meshql/client": "workspace:*",
