    "@meshql/http": "workspace:*",
    "@meshql/prisma": "workspace:*",
    "@prisma/client": "^6.9.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@meshql/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.0",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.5"
  }
}
